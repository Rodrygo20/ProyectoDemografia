library(survival)
library(ggplot2)
library(flexsurv)
datos_tarea<- read.table(file = "NCCTGLungCancer.txt", header= TRUE)
km_fit <- survfit(Surv(datos_tarea$time, datos_tarea$status)~ 1, data = datos_tarea)
t <- km_fit$time
S_t<- km_fit$surv
par(mfrow= c(1, 2), mar =c(4, 4, 3, 1))
plot(t, log(S_t),
main = "Exponencial",
xlab = "tiempo",
ylab = "logS_t",
pch = 16, col= "darkblue")
abline(lm(log(S_t)~t), col = "red", lwd= 2, lty = 2)
plot(log(t), log(-log(S_t)),
main = "Weibull",
xlab = "logS_t",
ylab = "log(-log(S_t))",
pch = 16, col= "cyan")
abline(lm(log(-log(S_t)) ~ log(t)), col = "red", lwd = 2, lty = 2)
mod_exp <- survreg(Surv(datos_tarea$time, datos_tarea$status)~1, data = datos_tarea, dist = "exponential")
mod_wei <- survreg(Surv(datos_tarea$time, datos_tarea$status)~1, data = datos_tarea, dist = "weibull")
logL_exp <- mod_exp$loglik[1] # L(lambda_hat) de tus apuntes
logL_wei <- mod_wei$loglik[1] # L(gamma_hat, lambda_hat)
estadistico_lambda <- 2 * (logL_wei - logL_exp)
p_valor <- pchisq(estadistico_lambda, df = 1, lower.tail = FALSE)
print(p_valor)
mod_gg <- flexsurvreg(Surv(datos_tarea$time, datos_tarea$status) ~ 1, data = datos_tarea, dist = "gengamma")
logL_gg <- mod_gg$loglik
AIC_exp <- -2 * logL_exp + 2 * 1
AIC_wei <- -2 * logL_wei + 2 * 2
AIC_gg  <- -2 * logL_gg  + 2 * 3
tabla_aic <- data.frame(
Modelo = c("Exponencial", "Weibull", "Gamma Generalizada"),
AIC = c(AIC_exp, AIC_wei, AIC_gg)
)
print(tabla_aic)
estadistico_gg <- 2 * (logL_gg - logL_wei)
p_valor_gg <- pchisq(estadistico_gg, df = 1, lower.tail = FALSE)
print(p_valor_gg)
plot(km_fit,
main = "Supervivencia NCCTG Lung Cancer",
xlab = "tiempo", ylab = "S(t)",
col = "black", lwd = 2)
t_seq <- seq(0, max(datos_tarea$time), length.out = 300)
lines(t_seq, exp(-exp(-coef(mod_exp)) * t_seq), col = "darkblue", lwd = 2, lty = 2)
mu_w  <- coef(mod_wei)
sig_w <- mod_wei$scale
lines(t_seq, exp(-exp((log(t_seq) - mu_w) / sig_w)), col = "cyan4", lwd = 2, lty = 2)
S_gg_list <- summary(mod_gg, t = t_seq, type = "survival", ci = FALSE)
lines(t_seq, S_gg_list[[1]]$est, col = "darkgreen", lwd = 2, lty = 2)
legend("topright",
legend = c("Kaplan-Meier", "Exponencial", "Weibull", "Gamma Generalizada"),
col    = c("black", "darkblue", "cyan4", "darkgreen"),
lwd    = 2, lty = c(1, 2, 2, 2))
View(pop_d)
View(pop_d)
View(SINA)
